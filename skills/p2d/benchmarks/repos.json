{
  "version": 2,
  "repos": [
    {
      "id": "nestjs-typescript-starter",
      "description": "Small real NestJS application used as an external backend TypeScript benchmark.",
      "url": "https://github.com/nestjs/typescript-starter.git",
      "commit": "c4d9330f5513eda0fb5df594f6b34a11fde1a934",
      "language": "typescript",
      "type": "nestjs-backend",
      "targets": [
        {
          "symbol": "AppService",
          "task_type": "service-discovery",
          "language": "typescript",
          "notes": "Nest service definition, controller injection, module provider, and unit test.",
          "expected_files": [
            "src/app.controller.spec.ts",
            "src/app.controller.ts",
            "src/app.module.ts",
            "src/app.service.ts"
          ]
        },
        {
          "symbol": "AppController",
          "task_type": "controller-discovery",
          "language": "typescript",
          "notes": "Nest controller definition, module registration, unit test, and e2e bootstrap.",
          "expected_files": [
            "src/app.controller.spec.ts",
            "src/app.controller.ts",
            "src/app.module.ts",
            "test/app.e2e-spec.ts"
          ]
        },
        {
          "symbol": "AppModule",
          "task_type": "module-discovery",
          "language": "typescript",
          "notes": "Nest module registration and test bootstrap.",
          "expected_files": [
            "src/app.module.ts",
            "src/main.ts",
            "test/app.e2e-spec.ts"
          ]
        },
        {
          "symbol": "getHello",
          "task_type": "method-discovery",
          "language": "typescript",
          "notes": "Method implementation, controller call, and unit test reference.",
          "expected_files": [
            "src/app.controller.spec.ts",
            "src/app.controller.ts",
            "src/app.service.ts"
          ]
        }
      ]
    },
