#!/usr/bin/env python3
"""Render a Markdown summary table from a saved P2D benchmark JSON report."""

from __future__ import annotations

import argparse
import json
from pathlib import Path


def latest_result(results_dir: Path) -> Path:
    files = sorted(results_dir.glob("p2d-benchmark-*.json"))
    if not files:
        raise SystemExit(f"No benchmark results found in {results_dir}")
    return files[-1]


def load_report(path: Path) -> dict:
    return json.loads(path.read_text(encoding="utf-8"))


def rows(report: dict) -> list[dict]:
    output = []
    for repo_report in report.get("external_repos", []):
        repo_id = repo_report.get("repo")
        for result in repo_report.get("results", []):
            output.append(
                {
                    "repo": repo_id,
                    "symbol": result.get("symbol", ""),
                    "standard": result.get("standard_tokens", ""),
                    "p2d": result.get("p2d_tokens", ""),
                    "savings": result.get("savings_percent", ""),
                    "recall": result.get("recall_percent", ""),
                    "precision": result.get("precision_percent", ""),
                }
            )
    return output


def main() -> int:
    parser = argparse.ArgumentParser(description="Render P2D benchmark summary markdown")
    parser.add_argument("result", nargs="?", help="Result JSON file. Defaults to latest.")
    parser.add_argument("--results-dir", default="benchmark/results")
    args = parser.parse_args()

    path = Path(args.result).resolve() if args.result else latest_result(Path(args.results_dir).resolve())
    report = load_report(path)
    print("| Repo | Symbol | Standard Tokens | P2D Tokens | Savings | Recall | Precision |")
    print("| :--- | :----- | --------------: | ---------: | ------: | -----: | --------: |")
    for row in rows(report):
        print(
            f"| {row['repo']} | {row['symbol']} | {row['standard']} | {row['p2d']} | "
            f"{row['savings']}% | {row['recall']}% | {row['precision']}% |"
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
