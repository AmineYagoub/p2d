#!/usr/bin/env python3
"""Check whether P2D can run with structural tools or fallback mode."""

from __future__ import annotations

import argparse
import subprocess
from pathlib import Path

from p2d_common import as_json, command_version, iter_source_files


def git_status(root: Path) -> dict:
    result = subprocess.run(
        ["git", "status", "--short"],
        cwd=root,
        text=True,
        capture_output=True,
        check=False,
    )
    if result.returncode != 0:
        return {"is_git_repo": False, "dirty": None, "entries": []}
    entries = [line for line in result.stdout.splitlines() if line.strip()]
    return {"is_git_repo": True, "dirty": bool(entries), "entries": entries}


def source_summary(root: Path) -> dict:
    counts: dict[str, int] = {}
    total = 0
    for path in iter_source_files(root):
        total += 1
        ext = path.suffix or "<none>"
        counts[ext] = counts.get(ext, 0) + 1
    return {"total": total, "by_extension": dict(sorted(counts.items()))}


def main() -> int:
    parser = argparse.ArgumentParser(description="Run P2D prerequisite checks")
    parser.add_argument("--root", default=".", help="Repository root")
    parser.add_argument("--json", action="store_true", help="Emit JSON")
    args = parser.parse_args()

    root = Path(args.root).resolve()
    report = {
        "root": str(root),
        "tools": {
            "ast_grep": command_version(["sg", "--version"]),
            "code_review_graph": command_version(["code-review-graph", "--version"]),
            "codemod": command_version(["npx", "codemod", "--version"]),
        },
        "git": git_status(root),
        "source": source_summary(root),
    }

    if args.json:
        print(as_json(report))
        return 0

    print("P2D Doctor")
    print(f"Root: {report['root']}")
    for name, status in report["tools"].items():
        mark = "yes" if status["available"] else "no"
        version = status["version"] or "not found"
        print(f"- {name}: {mark} ({version})")
    dirty = report["git"]["dirty"]
    if dirty is None:
        print("- git: not a repository")
    else:
        print(f"- git dirty: {'yes' if dirty else 'no'}")
    print(f"- source files: {report['source']['total']}")
    if report["git"]["dirty"]:
        print("Safety note: dirty worktree detected; only revert agent-owned hunks.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
