#!/usr/bin/env python3
"""Check whether P2D can run with structural tools or fallback mode."""

from __future__ import annotations

import argparse
import subprocess
from pathlib import Path

from p2d_common import as_json, command_version, iter_source_files


def git_status(root: Path) -> dict:
    result = subprocess.run(
        ["git", "status", "--short"],
        cwd=root,
        text=True,
        capture_output=True,
        check=False,
    )
    if result.returncode != 0:
        return {"is_git_repo": False, "dirty": None, "entries": []}
    entries = [line for line in result.stdout.splitlines() if line.strip()]
    return {"is_git_repo": True, "dirty": bool(entries), "entries": entries}


def detect_graph_db(root: Path) -> dict:
    db_path = root / ".code-review-graph" / "graph.db"
    return {"available": db_path.exists(), "path": str(db_path) if db_path.exists() else None}


def source_summary(root: Path) -> dict:
    counts: dict[str, int] = {}
    total = 0
    for path in iter_source_files(root):
        total += 1
        ext = path.suffix or "<none>"
        counts[ext] = counts.get(ext, 0) + 1
    return {"total": total, "by_extension": dict(sorted(counts.items()))}


def main() -> int:
    parser = argparse.ArgumentParser(description="Run P2D prerequisite checks")
    parser.add_argument("--root", default=".", help="Repository root")
    parser.add_argument("--json", action="store_true", help="Emit JSON")
    args = parser.parse_args()

    root = Path(args.root).resolve()

    cli = command_version(["code-review-graph", "--version"])
    db = detect_graph_db(root)

    report = {
        "root": str(root),
        "tools": {
            "ast_grep": command_version(["sg", "--version"]),
            "code_review_graph_cli": cli,
            "code_review_graph_db": db,
            "code_review_graph_mcp": {"available": None, "note": "not detectable from doctor script"},
            "code_review_graph": {"available": cli["available"]},
            "graph_db_present": db["available"],
        },
        "git": git_status(root),
        "source": source_summary(root),
    }

    if args.json:
        print(as_json(report))
        return 0

    print("P2D Doctor")
    print(f"Root: {report['root']}")

    ast = report["tools"]["ast_grep"]
    print(f"- ast_grep: {'yes' if ast['available'] else 'no'} ({ast.get('version') or 'not found'})")

    cli_v = cli.get("version") or "not found"
    print(f"- code_review_graph_cli: {'yes' if cli['available'] else 'no'} ({cli_v})")
    print(f"- code_review_graph_db: {'yes' if db['available'] else 'no'}" + (f" ({db['path']})" if db["available"] else ""))
    print("- code_review_graph_mcp: unknown (doctor script cannot inspect session MCP tools)")
    combined = "yes" if cli["available"] else "no"
    note = "" if cli["available"] else " (CLI unavailable; MCP may still be available to the agent)"
    print(f"- code_review_graph: {combined}{note}")

    dirty = report["git"]["dirty"]
    if dirty is None:
        print("- git: not a repository")
    else:
        print(f"- git dirty: {'yes' if dirty else 'no'}")
    print(f"- source files: {report['source']['total']}")
    if report["git"]["dirty"]:
        print("Safety note: dirty worktree detected; only revert agent-owned hunks.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
