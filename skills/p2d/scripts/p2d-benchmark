#!/usr/bin/env python3
"""Recall-aware P2D benchmark runner."""

from __future__ import annotations

import argparse
import json
from pathlib import Path

from p2d_common import as_json, bucket_counts, find_symbol, refs_as_dicts, safe_read


def load_expected(path: Path | None) -> set[str] | None:
    if path is None:
        return None
    data = json.loads(safe_read(path))
    return set(data.get("files", []))


def chars_for_files(root: Path, files: set[str]) -> int:
    total = 0
    for file in files:
        path = root / file
        if path.exists():
            total += len(safe_read(path))
    return total


def main() -> int:
    parser = argparse.ArgumentParser(description="Run a recall-aware P2D benchmark")
    parser.add_argument("symbol", help="Symbol to benchmark")
    parser.add_argument("--root", default=".", help="Repository root")
    parser.add_argument("--expected", help="Expected JSON with a files array")
    parser.add_argument("--json", action="store_true", help="Emit JSON")
    args = parser.parse_args()

    root = Path(args.root).resolve()
    refs = find_symbol(root, args.symbol)
    found_files = {ref.file for ref in refs}
    expected_files = load_expected(Path(args.expected).resolve() if args.expected else None)
    ground_truth = expected_files or found_files

    p2d_payload = refs_as_dicts(refs)
    standard_grep_chars = sum(len(f"{ref.file}:{ref.line}:{ref.text}\n") for ref in refs)
    standard_file_chars = chars_for_files(root, ground_truth)
    standard_tokens = max(1, (standard_grep_chars + standard_file_chars) // 4)
    p2d_tokens = max(1, len(json.dumps(p2d_payload)) // 4)

    true_positive_files = found_files & ground_truth
    false_negative_files = ground_truth - found_files
    false_positive_files = found_files - ground_truth
    recall = 1.0 if not ground_truth else len(true_positive_files) / len(ground_truth)
    precision = 1.0 if not found_files else len(true_positive_files) / len(found_files)
    savings = 1.0 - (p2d_tokens / standard_tokens)

    report = {
        "symbol": args.symbol,
        "root": str(root),
        "standard_tokens": standard_tokens,
        "p2d_tokens": p2d_tokens,
        "savings_percent": round(savings * 100, 2),
        "recall_percent": round(recall * 100, 2),
        "precision_percent": round(precision * 100, 2),
        "expected_files": sorted(ground_truth),
        "found_files": sorted(found_files),
        "false_negative_files": sorted(false_negative_files),
        "false_positive_files": sorted(false_positive_files),
        "categories": bucket_counts(refs),
    }

    if args.json:
        print(as_json(report))
        return 0 if recall == 1.0 else 1

    print(f"P2D Benchmark: {args.symbol}")
    print(f"- standard tokens: {standard_tokens}")
    print(f"- p2d tokens: {p2d_tokens}")
    print(f"- savings: {report['savings_percent']}%")
    print(f"- recall: {report['recall_percent']}%")
    print(f"- precision: {report['precision_percent']}%")
    if false_negative_files:
        print("- false negatives:")
        for file in sorted(false_negative_files):
            print(f"  - {file}")
    return 0 if recall == 1.0 else 1


if __name__ == "__main__":
    raise SystemExit(main())
