#!/usr/bin/env python3
"""Run bundled fixtures and all configured external P2D benchmark profiles."""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path


SCRIPT_DIR = Path(__file__).resolve().parent
SKILL_DIR = SCRIPT_DIR.parent
WORKSPACE_ROOT = SKILL_DIR.parent.parent
DEFAULT_CONFIG = SKILL_DIR / "benchmarks/repos.json"
DEFAULT_RESULTS_DIR = WORKSPACE_ROOT / "benchmark/results"
FIXTURE_DIR = WORKSPACE_ROOT / "test/fixtures/p2d"


def run(command: list[str], check: bool = False) -> subprocess.CompletedProcess:
    return subprocess.run(command, text=True, capture_output=True, check=check)


def load_config(path: Path) -> dict:
    return json.loads(path.read_text(encoding="utf-8"))


def run_fixture_check() -> dict:
    if not FIXTURE_DIR.exists():
        return {
            "name": "fixture-check",
            "exit_code": 0,
            "status": "skipped",
            "stdout": "Dev-only fixtures not present; skipped fixture check.",
            "stderr": "",
        }
    result = run([sys.executable, str(SCRIPT_DIR / "p2d-fixture-check")])
    return {
        "name": "fixture-check",
        "exit_code": result.returncode,
        "status": "passed" if result.returncode == 0 else "failed",
        "stdout": result.stdout.strip(),
        "stderr": result.stderr.strip(),
    }


def run_external_repo(repo_id: str, config: Path) -> dict:
    result = run(
        [
            sys.executable,
            str(SCRIPT_DIR / "p2d-fetch-benchmark-repo"),
            repo_id,
            "--config",
            str(config),
            "--json",
        ]
    )
    if result.stdout.strip():
        try:
            payload = json.loads(result.stdout)
        except json.JSONDecodeError:
            payload = {"repo": repo_id, "error": result.stdout.strip()}
    else:
        payload = {"repo": repo_id, "error": result.stderr.strip()}
    payload["exit_code"] = result.returncode
    return payload


def flatten_results(report: dict) -> list[dict]:
    rows = []
    for repo_report in report["external_repos"]:
        for result in repo_report.get("results", []):
            rows.append(
                {
                    "repo": repo_report.get("repo"),
                    "symbol": result.get("symbol"),
                    "standard_tokens": result.get("standard_tokens"),
                    "p2d_tokens": result.get("p2d_tokens"),
                    "savings_percent": result.get("savings_percent"),
                    "recall_percent": result.get("recall_percent"),
                    "precision_percent": result.get("precision_percent"),
                    "exit_code": result.get("exit_code"),
                }
            )
    return rows


def print_summary(report: dict) -> None:
    fixture_status = report["fixture_check"].get(
        "status", "passed" if report["fixture_check"]["exit_code"] == 0 else "failed"
    )
    print(f"Fixture check: {fixture_status}")
    for row in flatten_results(report):
        print(
            f"{row['repo']} :: {row['symbol']} | "
            f"savings {row['savings_percent']}% | "
            f"recall {row['recall_percent']}% | "
            f"precision {row['precision_percent']}%"
        )
    if report.get("saved_to"):
        print(f"Saved JSON: {report['saved_to']}")


def save_report(report: dict, results_dir: Path) -> Path:
    results_dir.mkdir(parents=True, exist_ok=True)
    timestamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    path = results_dir / f"p2d-benchmark-{timestamp}.json"
    report["saved_to"] = str(path)
    path.write_text(json.dumps(report, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    return path


def main() -> int:
    parser = argparse.ArgumentParser(description="Run all P2D benchmark checks")
    parser.add_argument("--config", default=str(DEFAULT_CONFIG), help="Benchmark repo config")
    parser.add_argument("--results-dir", default=str(DEFAULT_RESULTS_DIR), help="Directory for generated JSON")
    parser.add_argument("--no-save", action="store_true", help="Do not write benchmark/results JSON")
    parser.add_argument("--json", action="store_true", help="Emit aggregate JSON")
    args = parser.parse_args()

    config_path = Path(args.config).resolve()
    config = load_config(config_path)
    report = {
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "config": str(config_path),
        "fixture_check": run_fixture_check(),
        "external_repos": [],
    }
    for repo in config["repos"]:
        if repo.get("targets"):
            report["external_repos"].append(run_external_repo(repo["id"], config_path))

    failures = []
    if report["fixture_check"]["exit_code"] != 0:
        failures.append("fixture-check")
    for repo_report in report["external_repos"]:
        if repo_report.get("exit_code") != 0:
            failures.append(repo_report.get("repo", "unknown-repo"))
    report["failed"] = failures

    if not args.no_save:
        save_report(report, Path(args.results_dir).resolve())

    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        print_summary(report)
    return 1 if failures else 0


if __name__ == "__main__":
    raise SystemExit(main())
